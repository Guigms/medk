generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// --- ENUMS ---

enum Role {
  USER
  ADMIN
  ATTENDANT
}

enum OrderSource {
  ONLINE    
  COUNTER   
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  DELIVERING
  COMPLETED
  CANCELLED
}

enum PointType {
  EARNED
  REDEEMED
  EXPIRED
  BONUS
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

enum ReminderStatus {
  PENDING
  SENT
  CANCELLED
}

// --- MODELS ---

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  name          String
  password      String
  role          Role           @default(USER)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  favorites     Favorite[]
  orders        Order[]
  loyaltyPoints LoyaltyPoints?
  reminders     Reminder[]
  statusHistory OrderStatusHistory[]
  commissionRate Decimal        @default(0) @db.Decimal(5, 2)
  ordersSold     Order[]        @relation("SellerOrders")
  commissions    CommissionRecord[]

  @@map("users")
}

model Category {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  icon        String
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products Product[]
  coupons  Coupon[]

  @@map("categories")
}

model Product {
  id                   String         @id @default(cuid())
  name                 String
  barcode              String?        @unique
  purchaseBarcode      String?        @unique
  conversionFactor     Int            @default(1)
  brand                String?
  description          String         @db.Text
  price                Decimal        @db.Decimal(10, 2)
  image                String
  available            Boolean        @default(true)
  featured             Boolean        @default(false)
  discount             Int?
  requiresPrescription Boolean        @default(false)
  expiryDate           DateTime?
  stock                Int            @default(0)
  minStock             Int            @default(5)
  categoryId           String
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  category     Category       @relation(fields: [categoryId], references: [id])
  favorites    Favorite[]
  orderItems   OrderItem[]
  productClick ProductClick[]
  batches      Batch[]
  reminders    Reminder[]
  stockAlerts  StockAlert[]   // 🌟 ADICIONADO

  @@index([categoryId])
  @@map("products")
}

model Batch {
  id           String   @id @default(cuid())
  productId    String
  batchNumber  String
  quantity     Int
  expiryDate   DateTime
  purchaseDate DateTime
  cost         Decimal  @db.Decimal(10, 2)
  notes        String?  @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([expiryDate])
  @@map("batches")
}

model Banner {
  id        String   @id @default(cuid())
  title     String
  subtitle  String
  image     String
  link      String?
  active    Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("banners")
}

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  rating    Int
  comment   String   @db.Text
  date      DateTime
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("testimonials")
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
  @@index([productId])
  @@map("favorites")
}

model Order {
  id              String      @id @default(cuid())
  orderNumber     Int         
  userId          String?
  customerName    String
  customerPhone   String
  customerEmail   String?
  deliveryOption  String
  deliveryAddress String?
  subtotal        Decimal     @db.Decimal(10, 2)
  deliveryFee     Decimal     @db.Decimal(10, 2) @default(0)
  discount        Decimal     @db.Decimal(10, 2) @default(0)
  pointsUsed      Int         @default(0)
  totalAmount     Decimal     @db.Decimal(10, 2)
  status          OrderStatus @default(PENDING)
  paymentMethod   String?
  hasPrescription Boolean     @default(false)
  couponId        String?
  notes           String?     @db.Text
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  observation     String?
  changeFor       String?
  source          OrderSource @default(ONLINE)
  sellerId        String?
  seller          User?       @relation("SellerOrders", fields: [sellerId], references: [id])
  commissionRecord CommissionRecord?

  user          User?                @relation(fields: [userId], references: [id])
  coupon        Coupon?              @relation(fields: [couponId], references: [id])
  orderItems    OrderItem[]
  statusHistory OrderStatusHistory[] // 🌟 ADICIONADO

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("orders")
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  price     Decimal @db.Decimal(10, 2)

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

model ProductClick {
  id        String   @id @default(cuid())
  productId String
  clickedAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([clickedAt])
  @@map("product_clicks")
}

model LoyaltyPoints {
  id          String   @id @default(cuid())
  userId      String
  points      Int      @default(0)
  totalEarned Int      @default(0)
  totalSpent  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions PointTransaction[]

  @@unique([userId])
  @@map("loyalty_points")
}

model PointTransaction {
  id          String    @id @default(cuid())
  loyaltyId   String
  points      Int
  type        PointType
  description String
  orderId     String?
  createdAt   DateTime  @default(now())

  loyalty LoyaltyPoints @relation(fields: [loyaltyId], references: [id], onDelete: Cascade)

  @@index([loyaltyId])
  @@map("point_transactions")
}

model Coupon {
  id            String       @id @default(cuid())
  code          String       @unique
  description   String
  discountType  DiscountType
  discountValue Decimal      @db.Decimal(10, 2)
  minPurchase   Decimal?     @db.Decimal(10, 2)
  maxDiscount   Decimal?     @db.Decimal(10, 2)
  usageLimit    Int?
  usageCount    Int          @default(0)
  categoryId    String?
  validFrom     DateTime
  validUntil    DateTime
  active        Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  category Category? @relation(fields: [categoryId], references: [id])
  orders   Order[]

  @@index([code])
  @@map("coupons")
}

model Reminder {
  id           String         @id @default(cuid())
  userId       String
  productId    String
  reminderDate DateTime
  frequency    Int
  status       ReminderStatus @default(PENDING)
  lastSent     DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("reminders")
}

model SalesReport {
  id            String   @id @default(cuid())
  date          DateTime @unique
  totalOrders   Int      @default(0)
  totalRevenue  Decimal  @db.Decimal(10, 2) @default(0)
  totalProducts Int      @default(0)
  averageTicket Decimal  @db.Decimal(10, 2) @default(0)
  topProductId  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([date])
  @@map("sales_reports")
}

// 🌟 NOVOS MODELOS ADICIONADOS AQUI
model StockAlert {
  id        String   @id @default(cuid())
  productId String
  message   String   @db.Text
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("stock_alerts")
}

model OrderStatusHistory {
  id        String      @id @default(cuid())
  orderId   String
  userId    String      
  status    OrderStatus 
  createdAt DateTime    @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id])

  @@index([orderId])
  @@index([userId])
  @@map("order_status_history")
}

model CommissionRecord {
  id          String   @id @default(cuid())
  orderId     String   @unique
  sellerId    String
  amount      Decimal  @db.Decimal(10, 2)
  percentage  Decimal  @db.Decimal(5, 2)
  status      String   @default("PENDING") // PENDING (Pendente) ou PAID (Pago)
  createdAt   DateTime @default(now())

  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  seller      User     @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  @@index([sellerId])
  @@map("commission_records")
}